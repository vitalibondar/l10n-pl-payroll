<odoo>
    <data>
        <record id="rule_pl_payroll_payslip_line_own" model="ir.rule">
            <field name="name">Własne pozycje listy płac pracownika</field>
            <field name="model_id" ref="model_pl_payroll_payslip_line"/>
            <field name="domain_force">[('payslip_id.employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_payroll_employee'))]"/>
        </record>

        <record id="rule_pl_payroll_payslip_line_company" model="ir.rule">
            <field name="name">Pozycje list płac według firmy</field>
            <field name="model_id" ref="model_pl_payroll_payslip_line"/>
            <field name="domain_force">[('payslip_id.company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_payroll_officer')), (4, ref('group_payroll_manager'))]"/>
        </record>
    </data>
</odoo>
