<odoo>
    <data>
        <record id="module_category_pl_payroll" model="ir.module.category">
            <field name="name">Płace PL</field>
            <field name="sequence">25</field>
        </record>

        <record id="group_payroll_employee" model="res.groups">
            <field name="name">Pracownik płac</field>
            <field name="category_id" ref="module_category_pl_payroll"/>
        </record>

        <record id="group_payroll_officer" model="res.groups">
            <field name="name">Specjalista ds. płac</field>
            <field name="category_id" ref="module_category_pl_payroll"/>
            <field name="implied_ids" eval="[(4, ref('group_payroll_employee'))]"/>
        </record>

        <record id="group_payroll_manager" model="res.groups">
            <field name="name">Kierownik płac</field>
            <field name="category_id" ref="module_category_pl_payroll"/>
            <field name="implied_ids" eval="[(4, ref('group_payroll_officer'))]"/>
        </record>

        <record id="rule_pl_payroll_component_type_company" model="ir.rule">
            <field name="name">Typy składników według firmy</field>
            <field name="model_id" ref="model_pl_payroll_component_type"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_payroll_officer')), (4, ref('group_payroll_manager'))]"/>
        </record>

        <record id="rule_pl_payroll_parameter_company" model="ir.rule">
            <field name="name">Parametry płacowe według firmy</field>
            <field name="model_id" ref="model_pl_payroll_parameter"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_payroll_officer')), (4, ref('group_payroll_manager'))]"/>
        </record>

        <record id="rule_pl_payroll_payslip_own" model="ir.rule">
            <field name="name">Własne listy płac pracownika</field>
            <field name="model_id" ref="model_pl_payroll_payslip"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_payroll_employee'))]"/>
        </record>

        <record id="rule_pl_payroll_payslip_company" model="ir.rule">
            <field name="name">Listy płac według firmy</field>
            <field name="model_id" ref="model_pl_payroll_payslip"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_payroll_officer')), (4, ref('group_payroll_manager'))]"/>
        </record>
        <record id="rule_pl_payroll_creative_report_own" model="ir.rule">
            <field name="name">Własne raporty twórcze pracownika</field>
            <field name="model_id" ref="model_pl_payroll_creative_report"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_payroll_employee'))]"/>
        </record>

        <record id="rule_pl_payroll_creative_report_company" model="ir.rule">
            <field name="name">Raporty twórcze według firmy</field>
            <field name="model_id" ref="model_pl_payroll_creative_report"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_payroll_officer')), (4, ref('group_payroll_manager'))]"/>
        </record>

        <record id="rule_pl_payroll_zus_dra_company" model="ir.rule">
            <field name="name">Deklaracje ZUS DRA według firmy</field>
            <field name="model_id" ref="model_pl_payroll_zus_dra"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_payroll_officer')), (4, ref('group_payroll_manager'))]"/>
        </record>

        <record id="rule_pl_payroll_zus_dra_line_company" model="ir.rule">
            <field name="name">Pozycje ZUS DRA według firmy</field>
            <field name="model_id" ref="model_pl_payroll_zus_dra_line"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_payroll_officer')), (4, ref('group_payroll_manager'))]"/>
        </record>
    </data>
</odoo>
