<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pl_payroll_batch_wizard_form" model="ir.ui.view">
        <field name="name">pl.payroll.batch.wizard.form</field>
        <field name="model">pl.payroll.batch.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Payslips">
                <group>
                    <field name="company_id"/>
                    <field name="department_ids" widget="many2many_tags"/>
                </group>
                <group>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="auto_compute"/>
                </group>
                <footer>
                    <button name="action_generate" string="Generate" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_pl_payroll_batch_wizard" model="ir.actions.act_window">
        <field name="name">Generate Payslips</field>
        <field name="res_model">pl.payroll.batch.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_pl_payroll_batch_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>
