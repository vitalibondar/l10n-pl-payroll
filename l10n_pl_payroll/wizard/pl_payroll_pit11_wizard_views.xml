<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pl_payroll_pit11_wizard_form" model="ir.ui.view">
        <field name="name">pl.payroll.pit11.wizard.form</field>
        <field name="model">pl.payroll.pit11.wizard</field>
        <field name="arch" type="xml">
            <form string="Generowanie PIT-11">
                <group>
                    <div class="alert alert-info" role="status" colspan="2">
                        System uwzględni tylko zatwierdzone listy płac z wybranego roku i po wygenerowaniu otworzy gotowe informacje PIT-11.
                    </div>
                    <field name="year" options="{'enable_formatting': false, 'type': 'number'}"/>
                </group>
                <footer>
                    <button name="action_generate" string="Generuj i otwórz PIT-11" type="object" class="btn-primary"/>
                    <button string="Anuluj" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_pl_payroll_pit11_wizard" model="ir.actions.act_window">
        <field name="name">Generuj PIT-11</field>
        <field name="res_model">pl.payroll.pit11.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_pl_payroll_pit11_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>
