<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pl_payroll_zus_dra_wizard_form" model="ir.ui.view">
        <field name="name">pl.payroll.zus.dra.wizard.form</field>
        <field name="model">pl.payroll.zus.dra.wizard</field>
        <field name="arch" type="xml">
            <form string="Generowanie ZUS DRA">
                <group>
                    <div class="alert alert-info" role="status" colspan="2">
                        System uwzględni tylko zatwierdzone listy płac z wybranego miesiąca i po wygenerowaniu otworzy gotowe deklaracje ZUS DRA.
                    </div>
                    <field name="year" options="{'enable_formatting': false, 'type': 'number'}"/>
                    <field name="month" options="{'enable_formatting': false, 'type': 'number'}"/>
                </group>
                <footer>
                    <button name="action_generate" string="Generuj i otwórz DRA" type="object" class="btn-primary"/>
                    <button string="Anuluj" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_pl_payroll_zus_dra_wizard" model="ir.actions.act_window">
        <field name="name">Generuj ZUS DRA</field>
        <field name="res_model">pl.payroll.zus.dra.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_pl_payroll_zus_dra_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>
