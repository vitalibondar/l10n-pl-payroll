<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_contract_form_inherit_pl_payroll" model="ir.ui.view">
        <field name="name">hr.contract.form.inherit.pl.payroll</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='information']" position="inside">
                <group string="Rozliczenie podatkowo-składkowe PL">
                    <group string="Podatek i KUP">
                        <field name="kup_type"/>
                        <field name="kup_autorskie_pct" invisible="kup_type != 'autorskie'"/>
                        <field name="pit2_filed"/>
                        <field name="ulga_type"/>
                    </group>
                    <group string="PPK i ZUS">
                        <field name="ppk_participation"/>
                        <field name="ppk_ee_rate" invisible="ppk_participation == 'opt_out'"/>
                        <field name="ppk_additional" invisible="ppk_participation != 'additional'"/>
                        <field name="zus_code"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
