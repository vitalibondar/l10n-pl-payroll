<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pl_payroll_parameter_tree" model="ir.ui.view">
        <field name="name">pl.payroll.parameter.tree</field>
        <field name="model">pl.payroll.parameter</field>
        <field name="arch" type="xml">
            <list string="Payroll Parameters">
                <field name="code"/>
                <field name="name"/>
                <field name="value"/>
                <field name="value_type"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="view_pl_payroll_parameter_form" model="ir.ui.view">
        <field name="name">pl.payroll.parameter.form</field>
        <field name="model">pl.payroll.parameter</field>
        <field name="arch" type="xml">
            <form string="Payroll Parameter">
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="value"/>
                            <field name="value_type"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="company_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="note" placeholder="Optional notes..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pl_payroll_parameter" model="ir.actions.act_window">
        <field name="name">Parameters</field>
        <field name="res_model">pl.payroll.parameter</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
