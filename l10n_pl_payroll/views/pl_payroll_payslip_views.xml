<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pl_payroll_payslip_tree" model="ir.ui.view">
        <field name="name">pl.payroll.payslip.tree</field>
        <field name="model">pl.payroll.payslip</field>
        <field name="arch" type="xml">
            <list string="Listy płac" decoration-success="state == 'confirmed'" decoration-muted="state == 'cancelled'">
                <field name="employee_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="contract_id" optional="hide"/>
                <field name="kup_type" optional="show"/>
                <field name="gross"/>
                <field name="zus_total_ee" optional="hide"/>
                <field name="pit_due" optional="hide"/>
                <field name="net"/>
                <field name="total_employer_cost" optional="hide"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_pl_payroll_payslip_search" model="ir.ui.view">
        <field name="name">pl.payroll.payslip.search</field>
        <field name="model">pl.payroll.payslip</field>
        <field name="arch" type="xml">
            <search string="Listy płac">
                <field name="employee_id"/>
                <field name="contract_id"/>
                <field name="department_id"/>
                <field name="date_from"/>
                <filter name="filter_draft" string="Szkic" domain="[('state', '=', 'draft')]"/>
                <filter name="filter_computed" string="Obliczona" domain="[('state', '=', 'computed')]"/>
                <filter name="filter_confirmed" string="Zatwierdzona" domain="[('state', '=', 'confirmed')]"/>
                <filter name="filter_cancelled" string="Anulowana" domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter
                    name="filter_this_month"
                    string="Bieżący miesiąc"
                    domain="[('date_from', '&gt;=', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d')), ('date_from', '&lt;', (context_today() + relativedelta(months=1, day=1)).strftime('%Y-%m-%d'))]"
                />
                <filter
                    name="filter_last_month"
                    string="Poprzedni miesiąc"
                    domain="[('date_from', '&gt;=', (context_today() + relativedelta(months=-1, day=1)).strftime('%Y-%m-%d')), ('date_from', '&lt;', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d'))]"
                />
                <filter
                    name="filter_this_year"
                    string="Bieżący rok"
                    domain="[('date_from', '&gt;=', context_today().strftime('%Y-01-01')), ('date_from', '&lt;=', context_today().strftime('%Y-12-31'))]"
                />
                <group expand="0" string="Grupuj wg">
                    <filter name="group_by_employee" string="Pracownik" context="{'group_by': 'employee_id'}"/>
                    <filter name="group_by_department" string="Wydział" context="{'group_by': 'department_id'}"/>
                    <filter name="group_by_month" string="Miesiąc" context="{'group_by': 'date_from:month'}"/>
                    <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_pl_payroll_payslip_form" model="ir.ui.view">
        <field name="name">pl.payroll.payslip.form</field>
        <field name="model">pl.payroll.payslip</field>
        <field name="arch" type="xml">
            <form string="Lista płac">
                <header>
                    <button name="action_compute" string="Oblicz" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_confirm" string="Zatwierdź" type="object" class="btn-primary" invisible="state not in ['draft', 'computed']"/>
                    <button name="action_cancel" string="Anuluj" type="object" invisible="state == 'cancelled'"/>
                    <button name="action_sync_attendance" string="Synchronizuj nadgodziny" type="object"
                        class="btn-secondary" invisible="state != 'draft'"
                        title="Pobierz nadgodziny z ewidencji czasu pracy"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,computed,confirmed,cancelled"/>
                </header>
                <sheet>
                    <div class="alert alert-warning" role="alert" invisible="not creative_report_missing">
                        <strong>Uwaga:</strong> Brakuje zatwierdzonego raportu twórczego dla tej listy płac.
                        Bez niego nie należy rozliczać 50% kosztów autorskich.
                    </div>
                    <div class="alert alert-warning" role="alert" invisible="not below_minimum_wage">
                        <strong>Uwaga:</strong> Wynagrodzenie brutto jest niższe od proporcjonalnego minimalnego wynagrodzenia
                        dla tego wymiaru etatu.
                    </div>
                    <field name="creative_report_required" invisible="1"/>
                    <field name="creative_report_missing" invisible="1"/>
                    <field name="below_minimum_wage" invisible="1"/>
                    <div class="oe_title oe_right mb-3">
                        <label for="net"/>
                        <h1>
                            <field name="net" readonly="1" nolabel="1" class="oe_inline"/>
                            <span class="text-muted oe_inline">PLN</span>
                        </h1>
                        <div class="text-warning fw-semibold" invisible="not creative_report_missing">
                            Brakuje raportu twórczego
                        </div>
                        <div class="text-warning fw-semibold" invisible="not below_minimum_wage">
                            Poniżej minimalnego wynagrodzenia
                        </div>
                    </div>
                    <group col="2">
                        <group string="Pracownik i umowa">
                            <field name="employee_id" readonly="state != 'draft'"/>
                            <field name="contract_id" readonly="state != 'draft'"/>
                            <field name="date_from" readonly="state != 'draft'"/>
                            <field name="date_to" readonly="state != 'draft'"/>
                        </group>
                        <group string="Informacje">
                            <field name="state" readonly="1"/>
                            <field name="name" readonly="1"/>
                            <field name="department_id" readonly="1"/>
                            <field name="company_id" readonly="1"/>
                            <field name="gross" readonly="1"/>
                            <field name="total_employer_cost" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Rozliczenie pracownika">
                            <group>
                                <group string="Podsumowanie wypłaty">
                                    <field name="gross" readonly="1"/>
                                    <field name="net" readonly="1"/>
                                    <field name="kup_type" readonly="1"/>
                                    <field name="kup_amount" readonly="1"/>
                                    <field name="ppk_ee" readonly="1"/>
                                </group>
                                <group string="Czas pracy i absencje">
                                    <field name="etat_fraction" readonly="1"/>
                                    <field name="working_days_in_month" readonly="state != 'draft'"/>
                                    <field name="overtime_hours_150" readonly="state != 'draft'"/>
                                    <field name="overtime_hours_200" readonly="state != 'draft'"/>
                                    <field name="overtime_amount" readonly="1"/>
                                    <field name="attendance_synced" invisible="1"/>
                                    <field name="overtime_manual_override" invisible="1"/>
                                    <field name="attendance_worked_hours" readonly="1" invisible="not attendance_synced"/>
                                    <field name="attendance_scheduled_hours" readonly="1" invisible="not attendance_synced"/>
                                    <field name="attendance_sync_date" readonly="1" invisible="not attendance_synced"/>
                                    <field name="vacation_days" readonly="state != 'draft'"/>
                                    <field name="vacation_pay" readonly="1"/>
                                </group>
                            </group>
                            <group>
                                <group string="Składki ZUS pracownika">
                                    <field name="zus_emerytalne_ee" readonly="1"/>
                                    <field name="zus_rentowe_ee" readonly="1"/>
                                    <field name="zus_chorobowe_ee" readonly="1"/>
                                    <field name="zus_total_ee" readonly="1"/>
                                </group>
                                <group string="Składka zdrowotna i PIT">
                                    <field name="health_basis" readonly="1"/>
                                    <field name="health" readonly="1"/>
                                    <field name="taxable_income" readonly="1"/>
                                    <field name="pit_advance" readonly="1"/>
                                    <field name="pit_reducing" readonly="1"/>
                                    <field name="pit_due" readonly="1"/>
                                </group>
                            </group>
                            <group>
                                <group string="Chorobowe">
                                    <field name="sick_days" readonly="state != 'draft'"/>
                                    <field name="sick_days_100" readonly="state != 'draft'"/>
                                    <field name="ytd_sick_days" readonly="1"/>
                                    <field name="sick_leave_basis" readonly="1"/>
                                    <field name="sick_leave_amount" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Składki pracodawcy">
                            <group>
                                <group string="Składki ZUS pracodawcy">
                                    <field name="zus_emerytalne_er" readonly="1"/>
                                    <field name="zus_rentowe_er" readonly="1"/>
                                    <field name="zus_wypadkowe_er" readonly="1"/>
                                    <field name="zus_fp" readonly="1"/>
                                    <field name="zus_fgsp" readonly="1"/>
                                </group>
                                <group string="PPK i koszt zatrudnienia">
                                    <field name="ppk_er" readonly="1"/>
                                    <field name="total_employer_cost" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Składniki dodatkowe">
                            <field name="payslip_line_ids" readonly="state != 'draft'">
                                <list editable="bottom">
                                    <field name="component_type_id"/>
                                    <field name="name"/>
                                    <field name="category"/>
                                    <field name="amount"/>
                                    <field name="pit_taxable" widget="boolean_toggle"/>
                                    <field name="zus_included" widget="boolean_toggle"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                        <page string="Raport twórczy" invisible="not creative_report_required">
                            <group>
                                <field name="creative_report_id" readonly="1"/>
                            </group>
                        </page>
                        <page string="Uwagi">
                            <field
                                name="notes"
                                nolabel="1"
                                placeholder="Dodatkowe uwagi księgowe..."
                                readonly="state in ['confirmed', 'cancelled']"
                            />
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pl_payroll_payslip" model="ir.actions.act_window">
        <field name="name">Listy płac</field>
        <field name="res_model">pl.payroll.payslip</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_pl_payroll_payslip_search"/>
    </record>

    <record id="action_server_pl_payroll_batch_confirm" model="ir.actions.server">
        <field name="name">Zatwierdź listy płac</field>
        <field name="model_id" ref="model_pl_payroll_payslip"/>
        <field name="binding_model_id" ref="model_pl_payroll_payslip"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">if records:
    records.action_confirm()</field>
    </record>

    <record id="view_pl_payroll_payslip_grid" model="ir.ui.view">
        <field name="name">pl.payroll.payslip.grid</field>
        <field name="model">pl.payroll.payslip</field>
        <field name="arch" type="xml">
            <list editable="inline" multi_edit="1" default_order="employee_id">
                <field name="employee_id" readonly="1"/>
                <field name="department_id" readonly="1" optional="show"/>
                <field name="contract_id" readonly="1" optional="hide"/>
                <field name="date_from" readonly="1" column_invisible="1"/>
                <field name="working_days_in_month"/>
                <field name="overtime_hours_150"/>
                <field name="overtime_hours_200"/>
                <field name="overtime_amount" readonly="1" optional="hide"/>
                <field name="sick_days"/>
                <field name="sick_days_100"/>
                <field name="vacation_days"/>
                <field name="gross" readonly="1"/>
                <field name="zus_total_ee" readonly="1" optional="hide"/>
                <field name="pit_due" readonly="1" optional="hide"/>
                <field name="bonus_gross_total" readonly="1" optional="show"/>
                <field name="deduction_net_total" readonly="1" optional="show"/>
                <field name="net" readonly="1"/>
                <field name="state" widget="badge" readonly="1"/>
            </list>
        </field>
    </record>

    <record id="action_pl_payroll_payslip_grid" model="ir.actions.act_window">
        <field name="name">Edycja zbiorcza list płac</field>
        <field name="res_model">pl.payroll.payslip</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_pl_payroll_payslip_grid"/>
        <field name="search_view_id" ref="view_pl_payroll_payslip_search"/>
        <field name="domain">[('state', '=', 'draft')]</field>
        <field name="context">{'search_default_filter_this_month': 1}</field>
    </record>

    <record id="action_server_pl_payroll_batch_compute" model="ir.actions.server">
        <field name="name">Oblicz zaznaczone listy płac</field>
        <field name="model_id" ref="model_pl_payroll_payslip"/>
        <field name="binding_model_id" ref="model_pl_payroll_payslip"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">if records:
    records.action_compute()</field>
    </record>

    <record id="action_server_pl_payroll_batch_sync_attendance" model="ir.actions.server">
        <field name="name">Synchronizuj nadgodziny z ewidencją</field>
        <field name="model_id" ref="model_pl_payroll_payslip"/>
        <field name="binding_model_id" ref="model_pl_payroll_payslip"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">if records:
    records.action_batch_sync_attendance()</field>
    </record>
</odoo>
