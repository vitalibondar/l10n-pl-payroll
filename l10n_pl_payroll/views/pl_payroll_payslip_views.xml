<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pl_payroll_payslip_tree" model="ir.ui.view">
        <field name="name">pl.payroll.payslip.tree</field>
        <field name="model">pl.payroll.payslip</field>
        <field name="arch" type="xml">
            <tree string="Payslips" decoration-success="state == 'confirmed'" decoration-muted="state == 'cancelled'">
                <field name="employee_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="gross"/>
                <field name="net"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_pl_payroll_payslip_search" model="ir.ui.view">
        <field name="name">pl.payroll.payslip.search</field>
        <field name="model">pl.payroll.payslip</field>
        <field name="arch" type="xml">
            <search string="Payslips">
                <field name="employee_id"/>
                <field name="contract_id"/>
                <field name="department_id"/>
                <field name="date_from"/>
                <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="filter_computed" string="Computed" domain="[('state', '=', 'computed')]"/>
                <filter name="filter_confirmed" string="Confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter name="filter_cancelled" string="Cancelled" domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter
                    name="filter_this_month"
                    string="This Month"
                    domain="[('date_from', '&gt;=', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d')), ('date_from', '&lt;', (context_today() + relativedelta(months=1, day=1)).strftime('%Y-%m-%d'))]"
                />
                <filter
                    name="filter_last_month"
                    string="Last Month"
                    domain="[('date_from', '&gt;=', (context_today() + relativedelta(months=-1, day=1)).strftime('%Y-%m-%d')), ('date_from', '&lt;', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d'))]"
                />
                <filter
                    name="filter_this_year"
                    string="This Year"
                    domain="[('date_from', '&gt;=', context_today().strftime('%Y-01-01')), ('date_from', '&lt;=', context_today().strftime('%Y-12-31'))]"
                />
                <group expand="0" string="Group By">
                    <filter name="group_by_employee" string="Employee" context="{'group_by': 'employee_id'}"/>
                    <filter name="group_by_department" string="Department" context="{'group_by': 'department_id'}"/>
                    <filter name="group_by_month" string="Month" context="{'group_by': 'date_from:month'}"/>
                    <filter name="group_by_state" string="State" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_pl_payroll_payslip_form" model="ir.ui.view">
        <field name="name">pl.payroll.payslip.form</field>
        <field name="model">pl.payroll.payslip</field>
        <field name="arch" type="xml">
            <form string="Payslip">
                <header>
                    <button name="action_compute" string="Compute" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary" invisible="state not in ['draft', 'computed']"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state == 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,computed,confirmed,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group string="Payslip">
                            <field name="employee_id" readonly="state != 'draft'"/>
                            <field name="contract_id" readonly="state != 'draft'"/>
                            <field name="department_id" readonly="1"/>
                            <field name="company_id" readonly="1"/>
                        </group>
                        <group string="Period">
                            <field name="date_from" readonly="state != 'draft'"/>
                            <field name="date_to" readonly="state != 'draft'"/>
                            <field name="state" readonly="1"/>
                            <field name="name" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Gross">
                            <field name="gross" readonly="1"/>
                        </group>
                        <group string="Net">
                            <div class="oe_title">
                                <label for="net"/>
                                <h1>
                                    <field name="net" readonly="1" class="oe_inline"/>
                                </h1>
                            </div>
                        </group>
                    </group>
                    <group string="Employee Deductions">
                        <group string="ZUS">
                            <field name="zus_emerytalne_ee" readonly="1"/>
                            <field name="zus_rentowe_ee" readonly="1"/>
                            <field name="zus_chorobowe_ee" readonly="1"/>
                            <field name="zus_total_ee" readonly="1"/>
                        </group>
                        <group string="Health">
                            <field name="health_basis" readonly="1"/>
                            <field name="health" readonly="1"/>
                        </group>
                        <group string="KUP">
                            <field name="kup_type" readonly="1"/>
                            <field name="kup_amount" readonly="1"/>
                        </group>
                        <group string="PIT">
                            <field name="taxable_income" readonly="1"/>
                            <field name="pit_advance" readonly="1"/>
                            <field name="pit_reducing" readonly="1"/>
                            <field name="pit_due" readonly="1"/>
                        </group>
                        <group string="PPK">
                            <field name="ppk_ee" readonly="1"/>
                        </group>
                    </group>
                    <group string="Employer Side">
                        <group string="ZUS Employer">
                            <field name="zus_emerytalne_er" readonly="1"/>
                            <field name="zus_rentowe_er" readonly="1"/>
                            <field name="zus_wypadkowe_er" readonly="1"/>
                            <field name="zus_fp" readonly="1"/>
                            <field name="zus_fgsp" readonly="1"/>
                        </group>
                        <group string="PPK Employer">
                            <field name="ppk_er" readonly="1"/>
                        </group>
                        <group string="Total Employer Cost">
                            <field name="total_employer_cost" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes" placeholder="Internal notes..." readonly="state != 'draft'"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pl_payroll_payslip" model="ir.actions.act_window">
        <field name="name">Payslips</field>
        <field name="res_model">pl.payroll.payslip</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_pl_payroll_payslip_search"/>
    </record>
</odoo>
