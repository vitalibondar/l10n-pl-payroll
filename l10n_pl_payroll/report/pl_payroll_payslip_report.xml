<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="paperformat_pl_payroll_payslip" model="report.paperformat">
        <field name="name">Polish Payroll Payslip A4</field>
        <field name="default">False</field>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">30</field>
        <field name="margin_bottom">18</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line">False</field>
        <field name="header_spacing">12</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_pl_payroll_payslip" model="ir.actions.report">
        <field name="name">Pasek wynagrodzeń</field>
        <field name="model">pl.payroll.payslip</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">l10n_pl_payroll.report_pl_payroll_payslip_document</field>
        <field name="report_file">l10n_pl_payroll.report_pl_payroll_payslip_document</field>
        <field name="binding_model_id" ref="model_pl_payroll_payslip"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_pl_payroll_payslip"/>
        <field name="print_report_name">'Pasek wynagrodzen - %s - %s' % ((object.employee_id.name or 'pracownik'), str(object.date_from or '')[:7])</field>
    </record>
</odoo>
